# =============================================================================
# Lakehouse Contract Lab - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# All cloud integrations are optional and gated by the presence of their vars.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_PORT=8096
LOG_LEVEL=INFO

# --- OpenAI (optional: enriches review summary artifact) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_REFRESH=gpt-4o

# --- AWS S3 (optional: artifact storage) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
S3_ARTIFACT_BUCKET=lakehouse-contract-lab-artifacts

# --- Snowflake (optional: gold KPI export) ---
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=LAKEHOUSE_LAB
SNOWFLAKE_SCHEMA=GOLD
SNOWFLAKE_ROLE=SYSADMIN

# --- Databricks (optional: Unity Catalog export) ---
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi-your-databricks-token
DATABRICKS_CLUSTER_ID=your-cluster-id
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=lakehouse_lab

# --- Spark (auto-detected on macOS; set explicitly in Docker/CI) ---
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
SPARK_LOCAL_IP=127.0.0.1
